# ============================================================
# n8n Agent Backend — Environment Configuration
# Docs: see ENV_SETUP.md for how to obtain each value
# ============================================================

# ------------------------------------------------------------
# AI Providers  (at least one of Groq OR Gemini is required)
# ------------------------------------------------------------

# Groq — Primary LLM provider (llama-3.3-70b-versatile)
# Add multiple keys; the service round-robins and auto-retries on rate limits
GROQ_API_KEY1=gsk_...
GROQ_API_KEY2=gsk_...
GROQ_API_KEY3=gsk_...

# Google Gemini — Fallback LLM provider (gemini-2.0-flash)
GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# Backend Service
# ------------------------------------------------------------

# URL of the main BlockOps backend (Node.js)
# Use http://localhost:3001 for local dev, or your deployed URL in production
BACKEND_URL=http://localhost:3001

# USDO — OneChain native USD stablecoin coin type
# Format: <USDO_PACKAGE_ID>::usdo::USDO  (get package ID from OneChain docs)
USDO_PACKAGE_ID=0x
USDO_COIN_TYPE=0x::usdo::USDO
