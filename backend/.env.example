# ============================================================
# backend — Environment Configuration
# Docs: see ENV_SETUP.md at the project root
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=3000

# URL of the n8n agent backend (Python FastAPI — AI tool execution)
AGENT_BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# OneChain Network
# Defaults point to OneLabs public nodes — override if needed
# ------------------------------------------------------------
ONECHAIN_ACTIVE_NETWORK=testnet
ONECHAIN_TESTNET_RPC=https://rpc-testnet.onelabs.cc:443
ONECHAIN_MAINNET_RPC=https://rpc-mainnet.onelabs.cc:443
ONECHAIN_DEVNET_RPC=https://rpc-devnet.onelabs.cc:443
ONECHAIN_NETWORK=OneChain Testnet

# ------------------------------------------------------------
# Move Package IDs
# Fill in after publishing each Move module with `sui client publish`
# ------------------------------------------------------------
TOKEN_FACTORY_PACKAGE_ID=0x
NFT_FACTORY_PACKAGE_ID=0x
PAYMENT_PACKAGE_ID=0x
ONEDEX_PACKAGE_ID=0x
ONEID_PACKAGE_ID=0x
ONETRANSFER_PACKAGE_ID=0x
# USDO — OneChain native USD stablecoin (get from OneChain docs / testnet explorer)
USDO_PACKAGE_ID=0x
USDO_COIN_TYPE=0x::usdo::USDO

# ------------------------------------------------------------
# Backend Wallet (Ed25519 — signs on-chain transactions)
# Generate: sui keytool generate ed25519
# Keep secret — use a dedicated hot-wallet with minimal OCT balance
# ------------------------------------------------------------
BACKEND_WALLET_SECRET_KEY=

# ------------------------------------------------------------
# AI Providers
# At least one Groq key OR Gemini key is required for AI features
# ------------------------------------------------------------

# Groq — primary LLM (llama-3.3-70b-versatile)
# Multiple keys auto-rotate on rate limits (429 errors)
GROQ_API_KEY1=gsk_...
GROQ_API_KEY2=gsk_...
GROQ_API_KEY3=gsk_...

# Google Gemini — fallback LLM and price fetching (gemini-2.0-flash)
GEMINI_API_KEY=AIza...

# OpenAI — reserved for future features
OPENAI_API_KEY=

# ------------------------------------------------------------
# Pinata (IPFS — required for NFT metadata uploads)
# Sign up at app.pinata.cloud → API Keys → New Key
# ------------------------------------------------------------
PINATA_API_KEY=
PINATA_SECRET_KEY=

# ------------------------------------------------------------
# Supabase (conversation memory)
# Settings → API in your Supabase project dashboard
# Run backend/database/schema.sql to create required tables
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key

# ------------------------------------------------------------
# Admin
# Used to protect maintenance endpoints (e.g. /admin/cleanup)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
ADMIN_SECRET=

# ------------------------------------------------------------
# Gmail (email tool via nodemailer)
# Requires a Gmail App Password — NOT your account password
# Generate at: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
