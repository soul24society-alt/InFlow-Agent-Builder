# ============================================================
# Orbit AI Backend — OneChain Move Package Deployer
# ============================================================

# LLM Providers
# Multiple Groq keys for automatic fallback on rate limits (429 errors)
GROQ_API_KEY1=gsk_your_key_here
GROQ_API_KEY2=gsk_your_key_here
GROQ_API_KEY3=gsk_your_key_here

GEMINI_API_KEY=AIzaSy_your_key_here

# Node.js Backend (deploy proxy — receives packageName, network, ownerAddress)
BACKEND_URL=http://localhost:3001

# OneChain network (testnet | mainnet | devnet)
ONECHAIN_ACTIVE_NETWORK=testnet

# OneChain RPC endpoints (override if using a custom node)
ONECHAIN_TESTNET_RPC=https://rpc-testnet.onelabs.cc:443
ONECHAIN_MAINNET_RPC=https://rpc-mainnet.onelabs.cc:443
ONECHAIN_DEVNET_RPC=https://rpc-devnet.onelabs.cc:443

# Service Config
PORT=8000
SESSION_TTL_SECONDS=7200
LOG_LEVEL=info
